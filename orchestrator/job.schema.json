{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leetproof.dev/schemas/orchestrator-job-v1.json",
  "title": "LeetProof Orchestrator Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "tasks"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": 1
    },
    "job_id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "input_file",
        "input_sha256",
        "output_file",
        "depends_on"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
        },
        "input_file": {
          "type": "string",
          "pattern": "^[^\\\\/](?!.*(?:^|/)\\.\\.(?:/|$)).*\\.txt$"
        },
        "input_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "output_file": {
          "type": "string",
          "pattern": "^[^\\\\/](?!.*(?:^|/)\\.\\.(?:/|$)).*\\.lean$"
        },
        "depends_on": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
          }
        }
      }
    }
  }
}
