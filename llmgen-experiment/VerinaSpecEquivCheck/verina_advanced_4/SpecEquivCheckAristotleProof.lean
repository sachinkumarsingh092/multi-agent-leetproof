import Mathlib.Tactic

import Mathlib


namespace VerinaSpec

def LongestIncreasingSubsequence_precond (a : Array Int) : Prop :=
  True

def intMax (x y : Int) : Int :=
  if x < y then y else x

def LongestIncreasingSubsequence_postcond (a : Array Int) (result: Int) : Prop :=
  let allSubseq := (a.foldl fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]] |>.map List.reverse
  let increasingSubseqLens := allSubseq.filter (fun l => List.Pairwise (· < ·) l) |>.map (·.length)
  increasingSubseqLens.contains result ∧ increasingSubseqLens.all (· ≤ result)

end VerinaSpec

namespace LLMSpec

-- Indices are valid positions within the array.
def idxsInBounds (a : Array Int) (idxs : Array Nat) : Prop :=
  ∀ (k : Nat), k < idxs.size → idxs[k]! < a.size

-- Indices are strictly increasing (preserve order of the subsequence).
def idxsStrictlyIncreasing (idxs : Array Nat) : Prop :=
  ∀ (k : Nat), k + 1 < idxs.size → idxs[k]! < idxs[k + 1]!

-- Values picked by indices are strictly increasing.
def valsStrictlyIncreasing (a : Array Int) (idxs : Array Nat) : Prop :=
  ∀ (k : Nat),
    k + 1 < idxs.size →
      a[idxs[k]!]! < a[idxs[k + 1]!]!

-- A strictly increasing subsequence (represented by its index array).
def isStrictIncSubseqByIdxs (a : Array Int) (idxs : Array Nat) : Prop :=
  idxsInBounds a idxs ∧ idxsStrictlyIncreasing idxs ∧ valsStrictlyIncreasing a idxs

-- No input restriction: LIS length exists for all arrays.
def precondition (a : Array Int) : Prop :=
  True

-- result is the maximum possible length of any strictly increasing subsequence.
def postcondition (a : Array Int) (result : Int) : Prop :=
  0 ≤ result ∧
  result ≤ Int.ofNat a.size ∧
  (∃ (idxs : Array Nat), isStrictIncSubseqByIdxs a idxs ∧ Int.ofNat idxs.size = result) ∧
  (∀ (idxs : Array Nat), isStrictIncSubseqByIdxs a idxs → Int.ofNat idxs.size ≤ result)

end LLMSpec

section Proof

theorem precondition_equiv (a : Array Int) : VerinaSpec.LongestIncreasingSubsequence_precond a ↔ LLMSpec.precondition a := by
  -- Since both preconditions are True, the equivalence is trivial.
  simp [VerinaSpec.LongestIncreasingSubsequence_precond, LLMSpec.precondition]

noncomputable section AristotleLemmas

/-
The list of lists generated by VerinaSpec's foldl construction (mapped with reverse) contains exactly the subsequences of the input array.
-/
theorem verina_subseqs_iff (a : Array Int) (l : List Int) :
  l ∈ (a.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse ↔ List.Sublist l a.toList := by
    revert l;
    induction' a using Array.recOn with a ih;
    induction' a using List.reverseRecOn with a ih;
    · aesop;
    · simp_all +decide [ List.sublist_append_iff ];
      intro l; constructor;
      · grind +ring;
      · grind

/-
A list `l` is a sublist of `a` if and only if there exists a strictly increasing list of valid indices `idxs` such that `l` corresponds to the elements of `a` at those indices.
-/
theorem sublist_iff_exists_sorted_idxs (a : Array Int) (l : List Int) :
  List.Sublist l a.toList ↔ ∃ (idxs : List Nat), idxs.Pairwise (· < ·) ∧ (∀ i ∈ idxs, i < a.size) ∧ l = idxs.map (fun i => a.get! i) := by
    constructor <;> intro h;
    · -- Apply the lemma `List.sublist_iff_exists_fin_orderEmbedding_get_eq` to obtain the order embedding `f`.
      obtain ⟨f, hf⟩ : ∃ f : Fin l.length ↪o Fin a.size, l = List.map (fun i => a.get! (f i)) (List.finRange l.length) := by
        have := h
        have := List.sublist_iff_exists_fin_orderEmbedding_get_eq.mp this;
        obtain ⟨ f, hf ⟩ := this; use f; ext i; simp +decide [ hf, Array.get! ] ;
        by_cases hi : i < l.length <;> simp_all +decide [ List.get?_eq_none ];
        exact hf ⟨ i, hi ⟩ ▸ Iff.rfl;
      refine' ⟨ List.map ( fun i : Fin l.length => ( f i : ℕ ) ) ( List.finRange l.length ), _, _, _ ⟩ <;> norm_num [ List.pairwise_map ];
      · exact?;
      · exact hf;
    · obtain ⟨idxs, hidxs_pairwise, hidxs_bounds, hl⟩ := h
      have h_subseq : l = List.map (fun i => a.get! i) idxs := by
        exact hl;
      have h_subseq : List.Sublist (List.map (fun i => a.get! i) idxs) (List.map (fun i => a.get! i) (List.range a.size)) := by
        have h_subseq : List.Sublist idxs (List.range a.size) := by
          have h_sorted : List.Sorted (· < ·) idxs := by
            exact hidxs_pairwise
          have h_distinct : List.Nodup idxs := by
            exact h_sorted.nodup
          have h_subseq : List.Sublist idxs (List.range a.size) := by
            have h_perm : List.Perm idxs (List.filter (fun i => i ∈ idxs) (List.range a.size)) := by
              rw [ List.perm_iff_count ];
              intro i; by_cases hi : i ∈ idxs <;> simp_all +decide [ List.count_eq_zero_of_not_mem ] ;
            have h_subseq : List.Sublist (List.filter (fun i => i ∈ idxs) (List.range a.size)) (List.range a.size) := by
              exact?;
            have h_subseq : List.Sublist idxs (List.filter (fun i => i ∈ idxs) (List.range a.size)) := by
              have h_subseq : List.Sorted (· < ·) (List.filter (fun i => i ∈ idxs) (List.range a.size)) := by
                exact List.Sorted.filter _ ( List.pairwise_lt_range );
              exact List.eq_of_perm_of_sorted h_perm h_sorted h_subseq ▸ List.Sublist.refl _;
            exact h_subseq.trans ‹_›;
          exact h_subseq;
        exact h_subseq.map _;
      convert h_subseq using 1;
      refine' List.ext_get _ _ <;> simp +decide [ Array.get! ];
      exact fun n hn => by rw [ Array.getElem?_eq_getElem hn ] ; rfl;

/-
`LLMSpec.isStrictIncSubseqByIdxs` is equivalent to the indices being pairwise strictly increasing, valid, and the values at those indices being pairwise strictly increasing.
-/
theorem llm_spec_idxs_equiv (a : Array Int) (idxs : Array Nat) :
  LLMSpec.isStrictIncSubseqByIdxs a idxs ↔
  (idxs.toList.Pairwise (· < ·) ∧ (∀ i ∈ idxs.toList, i < a.size) ∧ (idxs.toList.map (fun i => a.get! i)).Pairwise (· < ·)) := by
    constructor;
    · rintro ⟨ h₁, h₂, h₃ ⟩;
      refine' ⟨ _, _, _ ⟩;
      · -- Since `idxs` is strictly increasing, the list of indices is also strictly increasing.
        have h_sorted : ∀ i j : Fin idxs.size, i < j → idxs[i]! < idxs[j]! := by
          intro i j hij;
          induction' j with j hj generalizing i;
          induction' j with j ih generalizing i;
          · tauto;
          · rcases eq_or_lt_of_le ( show i ≤ ⟨ j, by linarith ⟩ from Nat.le_of_lt_succ hij ) with rfl | hi <;> [ tauto; exact lt_trans ( ih ( by linarith ) _ hi ) ( h₂ _ ( by linarith ) ) ];
        rw [ List.pairwise_iff_get ] ; aesop;
      · -- By definition of `idxsInBounds`, for any `i` in `idxs.toList`, we have `i < a.size`.
        intros i hi
        obtain ⟨k, hk⟩ : ∃ k, k < idxs.size ∧ i = idxs[k]! := by
          obtain ⟨ k, hk ⟩ := List.mem_iff_get.mp hi; use k; aesop;
        exact hk.2.symm ▸ h₁ k hk.1;
      · have h_pairwise : ∀ i j : Nat, i < j → i < idxs.size → j < idxs.size → a.get! (idxs[i]!) < a.get! (idxs[j]!) := by
          intros i j hij hi hj
          induction' hij with k hk ih;
          · convert h₃ i ( by linarith ) using 1;
          · exact lt_trans ( ih ( Nat.lt_of_succ_lt hj ) ) ( h₃ _ ( by linarith ) );
        rw [ List.pairwise_iff_get ];
        aesop;
    · rintro ⟨ h₁, h₂, h₃ ⟩;
      refine' ⟨ _, _, _ ⟩;
      · intro k hk; specialize h₂ ( idxs[k]! ) ; aesop;
      · intro k hk;
        rw [ List.pairwise_iff_get ] at h₁;
        convert h₁ ⟨ k, by simpa using by linarith ⟩ ⟨ k + 1, by simpa using by linarith ⟩ ( Nat.lt_succ_self _ );
        · grind;
        · grind;
      · intro k hk;
        rw [ List.pairwise_map ] at h₃;
        have := List.pairwise_iff_get.mp h₃;
        convert this ⟨ k, by simpa using by linarith ⟩ ⟨ k + 1, by simpa using by linarith ⟩ ( Nat.lt_succ_self _ );
        · grind;
        · grind

end AristotleLemmas

theorem postcondition_equiv (a : Array Int) (result : Int) : LLMSpec.precondition a →
  (VerinaSpec.LongestIncreasingSubsequence_postcond a result ↔ LLMSpec.postcondition a result) := by
  simp [VerinaSpec.LongestIncreasingSubsequence_postcond, LLMSpec.postcondition];
  intro h
  constructor;
  · intro h
    obtain ⟨⟨l, hl_subseq, hl_eq⟩, hl_max⟩ := h
    have hl_bounds : 0 ≤ result ∧ result ≤ a.size := by
      have hl_bounds : l.length ≤ a.size := by
        have hl_bounds : l.Sublist a.toList := by
          convert verina_subseqs_iff a l |>.1 _ using 1 ; aesop;
        simpa using hl_bounds.length_le;
      exact ⟨ hl_eq ▸ Nat.cast_nonneg _, hl_eq ▸ Nat.cast_le.mpr hl_bounds ⟩
    have hl_lism : ∃ (idxs : Array ℕ), LLMSpec.isStrictIncSubseqByIdxs a idxs ∧ (↑idxs.size : ℤ) = result := by
      -- By definition of `sublist_iff_exists_sorted_idxs`, there exists a sorted list of indices `idxs_list` such that `l = idxs_list.map (fun i => a.get! i)`.
      obtain ⟨idxs_list, hidxs_list⟩ : ∃ (idxs_list : List ℕ), idxs_list.Pairwise (· < ·) ∧ (∀ i ∈ idxs_list, i < a.size) ∧ l = idxs_list.map (fun i => a.get! i) := by
        apply (sublist_iff_exists_sorted_idxs a l).mp;
        convert verina_subseqs_iff a l |>.1 _ using 1 ; aesop;
      use idxs_list.toArray;
      rw [ llm_spec_idxs_equiv ] ; aesop;
    have hl_max_lism : ∀ (idxs : Array ℕ), LLMSpec.isStrictIncSubseqByIdxs a idxs → (↑idxs.size : ℤ) ≤ result := by
      intro idxs hidxs
      have h_subseq : List.Sublist (idxs.toList.map (fun i => a.get! i)) a.toList := by
        convert sublist_iff_exists_sorted_idxs a ( List.map ( fun i => a.get! i ) idxs.toList ) |>.2 _ using 1;
        rw [ llm_spec_idxs_equiv ] at hidxs ; aesop
      have h_sorted : List.Pairwise (· < ·) (idxs.toList.map (fun i => a.get! i)) := by
        have := llm_spec_idxs_equiv a idxs |>.1 hidxs; aesop;
      have h_len : (idxs.toList.map (fun i => a.get! i)).length ≤ result := by
        have h_len : (idxs.toList.map (fun i => a.get! i)) ∈ (a.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse := by
          apply (verina_subseqs_iff a (List.map (fun i => a.get! i) idxs.toList)).mpr h_subseq;
        grind
      aesop
    exact ⟨hl_bounds.left, hl_bounds.right, hl_lism, hl_max_lism⟩;
  · intro h;
    constructor;
    · obtain ⟨ ⟨ idxs, hidxs₁, hidxs₂ ⟩, hidxs₃ ⟩ := h.2.2.1, h.2.2.2;
      -- By `sublist_iff_exists_sorted_idxs`, there exists `l` such that `l` is a subsequence of `a` and `l` is strictly increasing.
      obtain ⟨l, hl₁, hl₂⟩ : ∃ l : List Int, l.Sublist a.toList ∧ l.Pairwise (· < ·) ∧ l.length = idxs.size := by
        use idxs.toList.map (fun i => a.get! i);
        rw [ sublist_iff_exists_sorted_idxs ];
        rw [ llm_spec_idxs_equiv ] at hidxs₁ ; aesop;
      have := verina_subseqs_iff a l; aesop;
    · intro x hx; by_cases hx' : List.Pairwise ( fun x1 x2 => x1 < x2 ) x.reverse <;> simp_all +decide ;
      obtain ⟨idxs, hidxs⟩ : ∃ (idxs : List Nat), idxs.Pairwise (· < ·) ∧ (∀ i ∈ idxs, i < a.size) ∧ x.reverse = idxs.map (fun i => a.get! i) := by
        apply sublist_iff_exists_sorted_idxs a x.reverse |>.1;
        have h_sublist : ∀ (a : Array ℤ) (x : List ℤ), x ∈ (a.foldl (fun acc x => acc ++ acc.map (fun sub => x :: sub)) [[]]).map List.reverse → x.Sublist a.toList := by
          exact?;
        exact h_sublist a _ ( List.mem_map.mpr ⟨ _, hx, rfl ⟩ );
      convert h.2.2.2 ( idxs.toArray ) _ using 1;
      · replace hidxs := congr_arg List.length hidxs.2.2; aesop;
      · rw [ llm_spec_idxs_equiv ];
        aesop

end Proof